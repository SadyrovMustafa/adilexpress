# Файл базы внутри проекта (при деплое создаётся на шаге npm run build).
# Обязательно продублируйте в Vercel → Settings → Environment Variables (Production):
#   DATABASE_URL=file:./prisma/dev.db
#   ADMIN_PASSWORD=...
#   ADMIN_SECRET=...   (минимум 16 символов)
DATABASE_URL="file:./prisma/dev.db"

ADMIN_PASSWORD="change-me"
ADMIN_SECRET="use-at-least-16-random-characters"
